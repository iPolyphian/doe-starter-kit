#!/bin/sh
# Run fast claim audit checks before committing.
# Runs only checks marked fast=True — typically <1 second.
# To skip (emergency only): git commit --no-verify

export PYTHONIOENCODING=utf-8
python3 execution/audit_claims.py --hook > /dev/null 2>&1
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "═══ Pre-commit audit found issues ═══"
    echo ""
    python3 execution/audit_claims.py --hook 2>&1 | grep -E "FAIL|WARN"
    echo ""
    echo "Run 'python3 execution/audit_claims.py' for full details."
    echo "Fix issues or use --no-verify to skip."
    exit 1
fi

# ─── ESLint (blocks on errors, warns on warnings) ───
# Customize JS_PATH for your project (e.g. src/js/, lib/, app/scripts/)
JS_PATH="src/"

STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E "^${JS_PATH}.*\.js$" || true)
if [ -n "$STAGED_JS" ]; then
    npx eslint --no-warn-ignored $STAGED_JS 2>/dev/null
    if [ $? -ne 0 ]; then
        echo ""
        echo "═══ ESLint found errors in staged JS files ═══"
        echo ""
        echo "Fix errors or use SKIP_ESLINT=1 git commit to bypass."
        if [ "${SKIP_ESLINT:-0}" != "1" ]; then
            exit 1
        fi
    fi
fi

# ─── Stub detection (warnings only — never blocks commit) ───

if [ -n "$STAGED_JS" ]; then
    for f in $STAGED_JS; do
        STUBS=$(git diff --cached -- "$f" | grep -E '^\+.*return null\b' | grep -v '// ok' || true)
        if [ -n "$STUBS" ]; then
            echo "⚠ Stub detected in $f — 'return null' (is this intentional?)" >&2
        fi
        STUBS2=$(git diff --cached -- "$f" | grep -E '^\+.*return \[\]' | grep -v '// ok' || true)
        if [ -n "$STUBS2" ]; then
            echo "⚠ Stub detected in $f — 'return []' (is this intentional?)" >&2
        fi
        STUBS3=$(git diff --cached -- "$f" | grep -E '^\+.*function.*\{\s*\}' || true)
        if [ -n "$STUBS3" ]; then
            echo "⚠ Empty function body in $f (is this intentional?)" >&2
        fi
        STUBS4=$(git diff --cached -- "$f" | grep -E "^\+.*not.implemented|^\+.*NOT.IMPLEMENTED" || true)
        if [ -n "$STUBS4" ]; then
            echo "⚠ 'Not implemented' marker in $f" >&2
        fi
    done
fi

# ─── Audit sweep (warnings only — never blocks commit) ───

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

# Check for console.log in JS/TS files
JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|jsx|tsx)$' || true)
if [ -n "$JS_FILES" ]; then
    for f in $JS_FILES; do
        MATCHES=$(git diff --cached -- "$f" | grep -E '^\+.*console\.log' || true)
        if [ -n "$MATCHES" ]; then
            echo "⚠ console.log in $f (consider removing before production)" >&2
        fi
    done
fi

# Check for TODO without a reference (e.g. TODO(name) or TODO #123)
if [ -n "$STAGED_FILES" ]; then
    for f in $STAGED_FILES; do
        MATCHES=$(git diff --cached -- "$f" | grep -E '^\+.*TODO' | grep -vE 'TODO\s*\(|TODO\s*#' || true)
        if [ -n "$MATCHES" ]; then
            echo "⚠ TODO without reference in $f — use TODO(name) or TODO #123" >&2
        fi
    done
fi

# Check for hardcoded localhost URLs
if [ -n "$STAGED_FILES" ]; then
    for f in $STAGED_FILES; do
        MATCHES=$(git diff --cached -- "$f" | grep -E '^\+.*(localhost|127\.0\.0\.1|0\.0\.0\.0):[0-9]+' || true)
        if [ -n "$MATCHES" ]; then
            echo "⚠ Hardcoded localhost URL in $f — use config/env variable instead" >&2
        fi
    done
fi

# ─── innerHTML XSS check (warnings only — never blocks commit) ───

if [ -n "$STAGED_JS" ]; then
    for f in $STAGED_JS; do
        # Flag new innerHTML assignments that concatenate variables without _crmEsc()
        UNSAFE=$(git diff --cached -- "$f" | grep -E '^\+.*innerHTML\s*[\+\=]' | grep -v '_crmEsc\|_escHtml\|escapeHTML\|textContent\|// xss-safe' || true)
        if [ -n "$UNSAFE" ]; then
            echo "⚠ Potential XSS in $f — innerHTML with unescaped content. Use _crmEsc() or mark // xss-safe" >&2
        fi
    done
fi

# ─── STATE.md staleness check (warning only) ───

if [ -n "$STAGED_FILES" ]; then
    STATE_STAGED=$(echo "$STAGED_FILES" | grep -c "STATE.md" || true)
    CODE_STAGED=$(echo "$STAGED_FILES" | grep -cE '\.(js|jsx|ts|tsx|py|html|css|md)$' || true)
    if [ "$STATE_STAGED" = "0" ] && [ "$CODE_STAGED" -gt "0" ]; then
        echo "⚠ STATE.md not updated — consider updating if position, decisions, or context changed" >&2
    fi
fi

# ─── Sign-off enforcement (no unchecked [manual] in Done) ───
# Prevents features from skipping Awaiting Sign-off.
# Skip with: SKIP_SIGNOFF_CHECK=1 git commit -m '...'

if [ "${SKIP_SIGNOFF_CHECK:-0}" != "1" ]; then
    TODO_STAGED=$(echo "$STAGED_FILES" | grep -c "tasks/todo.md" || true)
    if [ "$TODO_STAGED" -gt "0" ]; then
        # Extract ## Done section and check for unchecked [manual] items
        UNCHECKED=$(sed -n '/^## Done/,$ p' tasks/todo.md | grep -c '\[ \] \[manual\]' || true)
        if [ "$UNCHECKED" -gt "0" ]; then
            echo ""
            echo "═══ Sign-off check failed ═══"
            echo ""
            echo "$UNCHECKED unchecked [manual] item(s) in ## Done."
            echo "Move feature to ## Awaiting Sign-off or check items off first."
            echo ""
            echo "Skip with: SKIP_SIGNOFF_CHECK=1 git commit -m '...'"
            exit 1
        fi
    fi
fi

# ─── todo.md structural lint (contract existence, retro step, [APP]+[manual]) ───
# Skip with: SKIP_TODO_LINT=1 git commit -m '...'

if [ "${SKIP_TODO_LINT:-0}" != "1" ]; then
    TODO_STAGED=$(echo "$STAGED_FILES" | grep -c "tasks/todo.md" || true)
    if [ "$TODO_STAGED" -gt "0" ]; then
        python3 execution/lint_todo.py 2>&1
        if [ $? -ne 0 ]; then
            exit 1
        fi
    fi
fi

# ─── Quality gate checkpoint (every 4 completed steps) ───
# Skip with: SKIP_QUALITY_GATE=1 git commit -m '...'

if [ "${SKIP_QUALITY_GATE:-0}" != "1" ]; then
    TODO_STAGED=$(echo "$STAGED_FILES" | grep -c "tasks/todo.md" || true)
    if [ "$TODO_STAGED" -gt "0" ]; then
        # Count completed steps in ## Current
        COMPLETED=$(sed -n '/^## Current$/,/^## / p' tasks/todo.md | grep -cE '^\s*[0-9]+[a-d]?\.\s+\[x\]' || true)
        if [ "$COMPLETED" -ge 4 ]; then
            # Read marker: feature_name:step_count
            FEATURE=$(sed -n '/^## Current$/,/^## / { /^### /p; }' tasks/todo.md | head -1 | sed 's/^### //' | sed 's/\s*\[.*//' | xargs)
            MARKER=$(cat .tmp/.quality-gate 2>/dev/null || echo ":")
            MARKER_FEATURE=$(echo "$MARKER" | cut -d: -f1)
            MARKER_STEP=$(echo "$MARKER" | cut -d: -f2)
            # Reset if feature changed
            if [ "$FEATURE" != "$MARKER_FEATURE" ]; then
                MARKER_STEP=0
            fi
            SINCE_GATE=$((COMPLETED - MARKER_STEP))
            if [ "$SINCE_GATE" -ge 4 ]; then
                echo ""
                echo "═══ Quality gate checkpoint required ═══"
                echo ""
                echo "$COMPLETED steps done, last gate at step $MARKER_STEP."
                echo "Run: python3 execution/quality_gate.py --checkpoint"
                echo ""
                echo "Skip with: SKIP_QUALITY_GATE=1 git commit -m '...'"
                exit 1
            fi
        fi
    fi
fi

# ─── Pre-retro gate (all steps complete, methodology must pass) ───
# Skip with: SKIP_RETRO_GATE=1 git commit -m '...'

if [ "${SKIP_RETRO_GATE:-0}" != "1" ]; then
    TODO_STAGED=$(echo "$STAGED_FILES" | grep -c "tasks/todo.md" || true)
    if [ "$TODO_STAGED" -gt "0" ]; then
        TOTAL=$(sed -n '/^## Current$/,/^## / p' tasks/todo.md | grep -cE '^\s*[0-9]+[a-d]?\.\s+\[' || true)
        DONE=$(sed -n '/^## Current$/,/^## / p' tasks/todo.md | grep -cE '^\s*[0-9]+[a-d]?\.\s+\[x\]' || true)
        if [ "$TOTAL" -gt "0" ] && [ "$TOTAL" = "$DONE" ]; then
            FEATURE=$(sed -n '/^## Current$/,/^## / { /^### /p; }' tasks/todo.md | head -1 | sed 's/^### //' | sed 's/\s*\[.*//' | xargs)
            MARKER=$(cat .tmp/.pre-retro-gate 2>/dev/null || echo ":")
            MARKER_FEATURE=$(echo "$MARKER" | cut -d: -f1)
            if [ "$FEATURE" != "$MARKER_FEATURE" ]; then
                echo ""
                echo "═══ Pre-retro gate required ═══"
                echo ""
                echo "All $TOTAL steps complete. Run pre-retro gate first."
                echo "Run: python3 execution/quality_gate.py --pre-retro"
                echo ""
                echo "Skip with: SKIP_RETRO_GATE=1 git commit -m '...'"
                exit 1
            fi
        fi
    fi
fi

# ─── Contract verification (solo mode gate) ───
# Checks current todo.md step's contract criteria are all [x] before allowing commit.
# Skip with: SKIP_CONTRACT_CHECK=1 git commit -m '...'
# Skip ALL hooks with: git commit --no-verify

if [ "${SKIP_CONTRACT_CHECK:-0}" != "1" ]; then
    python3 execution/check_contract.py 2>&1
    if [ $? -ne 0 ]; then
        exit 1
    fi
fi
