#!/bin/bash
# Pre-push hook: runs test_methodology.py --quick before every push.
# Fast structural checks only -- no execution tests, no pytest.
# Catches cross-reference breaks, contract issues, and DAG validation errors
# before they reach the remote and trigger CI.

set -e

# Find project root (where this hook lives)
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/.." && pwd)"

# ─── Auto-stamp tutorial docs version ───
# If the latest commit message contains a version tag (vX.Y.Z), stamp the
# tutorial HTML files and amend the commit so docs ship with correct version.
LATEST_MSG=$(git log -1 --format=%s 2>/dev/null)
VERSION_TAG=$(echo "$LATEST_MSG" | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | tail -1)

if [ -n "$VERSION_TAG" ] && [ -f "$PROJECT_ROOT/execution/stamp_tutorial_version.py" ]; then
    # Check if docs already have this version (skip if already stamped)
    CURRENT=$(grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' "$PROJECT_ROOT/docs/tutorial/index.html" 2>/dev/null | head -1)
    if [ "$CURRENT" != "$VERSION_TAG" ]; then
        echo "Stamping tutorial docs with $VERSION_TAG..."
        python3 "$PROJECT_ROOT/execution/stamp_tutorial_version.py" "$VERSION_TAG" --root "$PROJECT_ROOT"
        git add "$PROJECT_ROOT/docs/tutorial/"*.html
        git commit --amend --no-edit --no-verify
        echo "Docs stamped and amended into commit."
    fi
fi

echo "Running methodology checks (--quick)..."

if [ -f "$PROJECT_ROOT/execution/test_methodology.py" ]; then
    python3 "$PROJECT_ROOT/execution/test_methodology.py" --quick
    exit_code=$?
    if [ $exit_code -ne 0 ]; then
        echo ""
        echo "Pre-push blocked: test_methodology.py --quick failed."
        echo "Fix the issues above, then push again."
        echo "Skip with: git push --no-verify"
        exit 1
    fi
    echo "Methodology checks passed."
else
    echo "No test_methodology.py found -- skipping."
fi
